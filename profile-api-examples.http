}

###
### UPDATE STEP 4: Experiences
PUT {{baseUrl}}/profile/step/4
Content-Type: application/json

{
  "experiences": [
    {
      "title": "Senior Full Stack Developer",
      "company": "TechCorp Tunisia",
      "location": "Tunis",
      "startDate": "2023-01-15",
      "endDate": "2024-06-30",
      "description": "Led development of web applications using React and Node.js, managed team of 3 developers"
    },
    {
      "title": "Junior Full Stack Developer",
      "company": "StartupXYZ",
      "location": "Sfax",
      "startDate": "2022-06-01",
      "endDate": "2022-12-31",
      "description": "Built API endpoints and frontend components using React and Express.js"
    }
  ]
}

###
### UPDATE STEP 5: Projects
PUT {{baseUrl}}/profile/step/5
Content-Type: application/json

{
  "projects": [
    {
      "title": "E-Commerce Platform",
      "context": "personal",
      "description": "Full-stack e-commerce platform with real-time inventory and payment integration",
      "projectUrl": "https://ecommerce-example.com",
      "techStack": ["React", "Node.js", "PostgreSQL", "Stripe"],
      "date": "2023-06-01"
    },
    {
      "title": "Task Management App",
      "context": "professional",
      "description": "Collaborative task management application with real-time updates",
      "projectUrl": "https://taskapp-example.com",
      "techStack": ["React", "NestJS", "MongoDB", "Socket.io"],
      "date": "2023-09-15"
    }
  ]
}

