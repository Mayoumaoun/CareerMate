###
### ========== STEP 8️⃣: UPDATE STEP 8 - TARGET PROFILE (FINAL STEP) ==========
### Ajouter le profil cible / objectifs de carrière (Step 8 - ÉTAPE FINALE)
###
PUT {{baseUrl}}/profile/step/8
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "shortTermObjective": "Devenir Senior Developer dans une startup tech innovante",
  "longTermObjective": "Créer ma propre entreprise de développement logiciel",
  "targetPositions": [
    "Senior Full Stack Developer",
    "Technical Lead",
    "Engineering Manager"
  ],
  "sectorPreferences": [
    {
      "name": "Technology",
      "interest": "very_interested",
      "weight": 5
    },
    {
      "name": "Fintech",
      "interest": "very_interested",
      "weight": 4
    },
    {
      "name": "E-Commerce",
      "interest": "somewhat_interested",
      "weight": 3
    }
  ],
  "minSalary": 50000,
  "maxSalary": 100000,
  "salaryType": "gross",
  "contractTypes": [
    {
      "type": "cdi",
      "preferred": true
    },
    {
      "type": "freelance",
      "preferred": false
    }
  ],
  "targetCities": [
    "Tunis",
    "Paris",
    "Berlin"
  ],
  "remotePreference": {
    "type": "hybrid",
    "hybridDays": 3
  },
  "availability": "immediate"
}

###
### ========== GET PROFILE ==========
### Récupérer le profil complet avec toutes les étapes
###
GET {{baseUrl}}/profile
Authorization: Bearer {{token}}

###
### ========== GET PROFILE SUMMARY ==========
### Récupérer le résumé du profil avec score et pourcentage de complétude
###
GET {{baseUrl}}/profile/summary
Authorization: Bearer {{token}}

