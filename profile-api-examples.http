    }
  ]
}


###
### UPDATE STEP 6: Languages
PUT {{baseUrl}}/profile/step/6
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "languages": [
    {
      "language": "Français",
      "level": "native"
    },
    {
      "language": "English",
      "level": "C1",
      "certificate": "https://example.com/certs/toefl.pdf"
    },
    {
      "language": "Español",
      "level": "B2"
    }
  ]
}

###
### UPDATE STEP 7: Certifications
PUT {{baseUrl}}/profile/step/7
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "certifications": [
    {
      "name": "AWS Solutions Architect Associate",
