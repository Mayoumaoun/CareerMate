      "organization": "freeCodeCamp",
      "date": "2022-03-15",
      "domain": "Web Development",
      "context": "Online certification"
    }
  ]
}

###
### ERROR EXAMPLES
###

### Invalid age (under 16)
PUT {{baseUrl}}/profile/step/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Young",
  "lastName": "Person",
  "phone": "+33612345678",
  "country": "France",
  "city": "Paris",
  "dateOfBirth": "2010-05-15",
  "gender": "male"
}

###
### Duplicate skills (should fail)
PUT {{baseUrl}}/profile/step/3
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skills": [
    {
      "name": "React",
      "category": "tech",
      "level": "advanced"
    },
    {
      "name": "React",
      "category": "tech",
      "level": "beginner"
    }
  ]
}

###
### Invalid date range (end before start)
PUT {{baseUrl}}/profile/step/4
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "experiences": [
    {
      "title": "Developer",
      "company": "Company",
      "location": "Paris",
      "startDate": "2023-12-31",
      "endDate": "2023-01-01",
      "description": "Invalid date range"
    }
  ]
}
