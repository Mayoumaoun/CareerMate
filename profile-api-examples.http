###
### ========== UPDATE TARGET PROFILE (Modifier étape 8) ==========
### Modifier le profil cible si nécessaire
###
PUT {{baseUrl}}/profile/step/8
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "shortTermObjective": "Devenir Tech Lead dans une grande entreprise tech",
  "longTermObjective": "Créer un SaaS rentable",
  "targetPositions": [
    "Tech Lead",
    "Senior Architect",
    "CTO"
  ],
  "minSalary": 80000,
  "maxSalary": 150000,
  "salaryType": "gross",
  "availability": "3 months"
}

