### Profile API Examples
### Copy and paste these into a .http file or use REST Client extension

@baseUrl = http://localhost:3000/api
@userId = 1

###
### 1. CREATE COMPLETE PROFILE (All Steps at Once)
###
POST {{baseUrl}}/profile
Content-Type: application/json

{
  "step1": {
    "firstName": "Ahmed",
    "lastName": "Ben Mohamed",
    "phone": "+21625123456",
    "country": "Tunisia",
    "city": "Tunis",
    "dateOfBirth": "1998-05-15",
    "gender": "male",
    "email": "ahmed@example.com",
    "address": "123 Avenue de la Liberté",
    "zipCode": "1001"
  },
  "step2": {
    "userLevel": "Junior",
    "education": [
      {
        "degree": "Licence Informatique",
        "institution": "Université de Tunis",
        "field": "Computer Science",
        "startDate": "2020-09-01",
        "endDate": "2023-06-30"
      }
    ]
  },
  "step3": {
    "skills": [
      {
        "name": "React",
        "category": "tech",
        "level": "intermediate"
      },
      {
        "name": "Node.js",
        "category": "tech",
        "level": "intermediate"
      },
      {
        "name": "TypeScript",
        "category": "tech",
        "level": "intermediate"
      },
      {
        "name": "Communication",
        "category": "soft",
        "level": "advanced"
      }
    ]
  },
  "step4": {
    "experiences": [
      {
        "title": "Full Stack Developer",
        "company": "TechCorp Tunisia",
        "location": "Tunis",
        "startDate": "2023-01-15",
        "endDate": "2024-01-15",
        "description": "Built and maintained web applications using React and Node.js"
      }
    ]
  },
  "step5": {
    "projects": [
      {
        "title": "E-Commerce Platform",
        "context": "personal",
        "description": "Full-stack e-commerce platform with payment integration",
        "projectUrl": "https://ecommerce.example.com",
        "techStack": ["React", "Node.js", "PostgreSQL"],
        "date": "2023-06-01"
      }
    ]
  },
  "step6": {
    "languages": [
      {
        "language": "English",
        "level": "C1"
      },
      {
        "language": "Arabic",
        "level": "native"
      },
      {
        "language": "French",
        "level": "B2"
      }
    ]
  },
  "step7": {
    "certifications": [
      {
        "name": "AWS Solutions Architect Associate",
        "organization": "Amazon",
        "date": "2023-08-01",
        "domain": "Cloud Computing",
        "context": "Professional certification",
        "url": "https://aws.amazon.com"
      }
    ]
  }
}

###
### 2. GET USER PROFILE
###
GET {{baseUrl}}/profile/{{userId}}

###
### 3. GET PROFILE SUMMARY
###
GET {{baseUrl}}/profile/{{userId}}/summary

###
### STEP-BY-STEP UPDATES
###

### UPDATE STEP 1: Personal Information
PUT {{baseUrl}}/profile/step/1
Content-Type: application/json

{
  "firstName": "Ahmed",
  "lastName": "Ben Mohamed",
  "phone": "+21625987654",
  "country": "Tunisia",
  "city": "Sfax",
  "dateOfBirth": "1998-05-15",
  "gender": "male",
  "email": "ahmed.new@example.com",
  "address": "456 Rue de la République",
  "zipCode": "3000"
}

###
### UPDATE STEP 2: Education & Level
PUT {{baseUrl}}/profile/step/2
Content-Type: application/json

{
  "userLevel": "Senior",
  "education": [
    {
      "degree": "Licence Informatique",
      "institution": "Université de Tunis",
      "field": "Computer Science",
      "startDate": "2020-09-01",
      "endDate": "2023-06-30"
    },
    {
      "degree": "Master Informatique Avancée",
      "institution": "Université de Sousse",
      "field": "Advanced Computer Science",
      "startDate": "2023-09-01"
    }
  ]
}

###
### UPDATE STEP 3: Skills
PUT {{baseUrl}}/profile/step/3
Content-Type: application/json

{
  "skills": [
    {
      "name": "React",
      "category": "tech",
      "level": "advanced"
    },
    {
      "name": "NestJS",
      "category": "tech",
      "level": "advanced"
    },
    {
      "name": "TypeScript",
      "category": "tech",
      "level": "advanced"
    },
    {
      "name": "PostgreSQL",
      "category": "tech",
      "level": "intermediate"
    },
    {
      "name": "Docker",
