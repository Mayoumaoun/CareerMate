### Profile API Examples - Progressive Profile Creation (Step 1-8)
### Copy and paste these into a .http file or use REST Client extension
### All routes require authentication (JWT token in Authorization header)

@baseUrl = http://localhost:3000/api
@token = your_jwt_token_here

###
### ========== STEP 1️⃣: CREATE PROFILE WITH STEP 1 ONLY ==========
### Créer le profil avec Étape 1 (infos persos)
### ✅ REQUIRED: Numéro de téléphone tunisien
###
POST {{baseUrl}}/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "step1": {
    "firstName": "MOEZ",
    "lastName": "Ben Mohamed",
    "phone": "+21625123456",
    "country": "Tunisia",
    "city": "Tunis",
    "dateOfBirth": "1998-05-15",
    "gender": "male"
  },
  "bio": "Je suis un développeur passionné par les technologies web et mobile"
}

###
### ========== GET PROFILE ==========
### Récupérer le profil actuel
###
GET {{baseUrl}}/profile
Authorization: Bearer {{token}}

###
### ========== GET PROFILE SUMMARY ==========
### Récupérer un résumé du profil avec score et pourcentage de complétude
###
GET {{baseUrl}}/profile/summary
Authorization: Bearer {{token}}

###
### ========== STEP 2️⃣: UPDATE STEP 2 - EDUCATION ==========
### Ajouter l'éducation (Step 2)
###
PUT {{baseUrl}}/profile/step/2
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "userLevel": "Junior",
  "education": [
    {
      "degree": "Licence Informatique",
      "institution": "Université de Tunis",
      "field": "Computer Science",
      "startDate": "2020-09-01",
      "endDate": "2023-06-30",
      "location": "Tunis"
    },
    {
      "degree": "Master Développement Web",
      "institution": "ESI",
      "field": "Web Development",
      "startDate": "2023-09-01",
      "endDate": "2025-06-30",
      "location": "Tunis"
    }
  ]
}

###
### ========== STEP 3️⃣: UPDATE STEP 3 - SKILLS ==========
### Ajouter les compétences (Step 3)
### ✅ Niveaux valides: beginner, intermediate, advanced, expert
###
PUT {{baseUrl}}/profile/step/3
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skills": [
    {
      "name": "React",
      "level": "advanced"
    },
    {
      "name": "Node.js",
      "level": "intermediate"
    },
    {
      "name": "TypeScript",
      "level": "intermediate"
    },
    {
      "name": "PostgreSQL",
      "level": "intermediate"
    },
    {
      "name": "Docker",
      "level": "beginner"
    }
  ]
}

###
### ========== STEP 4️⃣: UPDATE STEP 4 - EXPERIENCES ==========
### Ajouter les expériences professionnelles (Step 4)
###
PUT {{baseUrl}}/profile/step/4
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "experiences": [
    {
      "title": "Développeur Frontend",
      "company": "StartUp Tech",
      "location": "Tunis",
      "startDate": "2023-07-01",
      "endDate": "2024-12-31",
      "description": "Développement d'applications React, intégration API REST, gestion état avec Redux"
    },
    {
      "title": "Développeur Full Stack Freelance",
      "company": "Freelance",
      "location": "Remote",
      "startDate": "2024-01-01",
      "endDate": "2025-04-05",
      "description": "Création de sites e-commerce, applications MERN, consultation technique"
    }
  ]
}

###
### ========== STEP 5️⃣: UPDATE STEP 5 - PROJECTS ==========
### Ajouter les projets (Step 5)
### ℹ️ Pour créer plusieurs projets, passez-les tous dans la liste "projects"
###
PUT {{baseUrl}}/profile/step/5
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "projects": [
    {
      "title": "E-Commerce Platform",
      "context": "Projet personnel",
      "description": "Plateforme e-commerce complète avec React, Node.js et MongoDB. Intégration Stripe pour paiements",
      "techStack": ["React", "Node.js", "MongoDB", "Stripe"],
      "projectUrl": "https://github.com/ahmed/ecommerce",
      "date": "2024-06-15"
    },
    {
      "title": "Task Management App",
      "context": "Projet freelance",
      "description": "Application de gestion de tâches avec collaboration temps réel et notifications",
      "techStack": ["React", "Express", "PostgreSQL", "Socket.io"],
      "projectUrl": "https://task-app.example.com",
      "date": "2024-03-20"
    },
    {
      "title": "AI Chat Bot",
      "context": "Projet scolaire",
      "description": "Chatbot IA utilisant OpenAI API intégré dans une application web",
      "techStack": ["React", "Node.js", "OpenAI API", "Redis"],
      "projectUrl": "https://github.com/ahmed/chatbot",
      "date": "2024-01-10"
    }
  ]
}

###
### ========== STEP 6️⃣: UPDATE STEP 6 - LANGUAGES ==========
### Ajouter les langues (Step 6)
### ✅ Niveaux CEFR valides: A1, A2, B1, B2, C1, C2, native
###
PUT {{baseUrl}}/profile/step/6
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "languages": [
    {
      "language": "French",
      "level": "native",
      "certificate": "https://certificates.example.com/french-native.pdf"
    },
    {
      "language": "English",
      "level": "C1",
      "certificate": "https://certificates.example.com/english-c1.pdf"
    },
    {
      "language": "Arabic",
      "level": "B2"
    },
    {
      "language": "German",
      "level": "A2"
    }
  ]
}

###
### ========== STEP 7️⃣: UPDATE STEP 7 - CERTIFICATIONS ==========
### Ajouter les certifications (Step 7)
###
PUT {{baseUrl}}/profile/step/7
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "certifications": [
    {
      "name": "AWS Certified Solutions Architect",
      "organization": "Amazon Web Services",
      "date": "2025-06-20",
      "domain": "Cloud Architecture",
      "context": "Professional Development",
      "url": "https://credentials.example.com/aws-cert-123"
    },
    {
      "name": "Kubernetes Administrator Certification",
      "organization": "The Linux Foundation",
      "date": "2024-12-15",
      "domain": "Container Orchestration",
      "context": "Professional Development",
      "url": "https://credentials.example.com/cka-456"
    },
    {
      "name": "Professional Scrum Master",
      "organization": "Scrum.org",
      "date": "2024-03-10",
      "domain": "Project Management",
      "context": "Professional Development",
      "url": "https://credentials.example.com/psm-789"
    }
  ]
}

###
### ========== STEP 8️⃣: UPDATE STEP 8 - TARGET PROFILE / CAREER GOALS ==========
### Définir le profil cible et les préférences de carrière (Step 8)
### ✅ Niveaux d'intérêt: not_interested, somewhat_interested, very_interested
### ✅ Types de contrats: cdi, cdd, stage, freelance, interim
### ✅ Types de travail: full_remote, hybrid, onsite
### ✅ Disponibilité: immediate, two_weeks, one_month, two_months, three_months
###
PUT {{baseUrl}}/profile/step/8
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "targetPosition": [
    "Senior Full Stack Developer",
    "Tech Lead"
  ],
  "preferredLocations": ["Tunis", "Remote"],
  "salaryExpectation": {
    "min": 2500,
    "max": 4000,
    "type": "net"
  },
  "preferredContractTypes": [
    {
      "type": "cdi",
      "preferred": true
    },
    {
      "type": "freelance",
      "preferred": false
    }
  ],
  "remotePreference": {
    "type": "hybrid",
    "flexible": true
  },
  "availability": "immediate",
  "sectorPreferences": [
    {
      "name": "Technology",
      "interest": "very_interested",
      "weight": 5
    },
    {
      "name": "FinTech",
      "interest": "very_interested",
      "weight": 4
    },
    {
      "name": "HealthTech",
      "interest": "somewhat_interested",
      "weight": 3
    }
  ],
  "careerGoals": {
    "shortTerm": "Devenir Senior Developer dans une startup tech innovante",
    "longTerm": "Créer ma propre startup ou devenir CTO"
  },
  "preferredWorkEnvironment": "Entreprise dynamique avec bonne culture DevOps",
  "additionalRequirements": "Formation continue, flexibilité horaire, télétravail 3 jours/semaine"
}

###
### ========== UPDATE COMPLETE PROFILE ==========
### Mettre à jour tout le profil d'un coup (optionnel)
### Utile pour les mises à jour massives
###
PUT {{baseUrl}}/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "step1": {
    "firstName": "MOEZ",
    "lastName": "Ben Mohamed",
    "phone": "+21625123456",
    "country": "Tunisia",
    "city": "Tunis",
    "dateOfBirth": "1998-05-15",
    "gender": "male"
  },
  "bio": "Je suis un développeur passionné par les technologies web et mobile",
  "step2": {
    "userLevel": "Junior",
    "education": [
      {
        "degree": "Licence Informatique",
        "institution": "Université de Tunis",
        "field": "Computer Science",
        "startDate": "2020-09-01",
        "endDate": "2023-06-30",
        "location": "Tunis"
      }
    ]
  },
  "step3": {
    "skills": [
      {
        "name": "React",
        "level": "advanced"
      },
      {
        "name": "Node.js",
        "level": "intermediate"
      }
    ]
  }
}
### Modifier l'étape 1 (par exemple, changer la ville)
###
PUT {{baseUrl}}/profile/step/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Ahmed",
  "lastName": "Ben Mohamed",
  "phone": "+21625123456",
  "country": "France",
  "city": "Paris",
  "dateOfBirth": "1998-05-15",
  "gender": "male",
  "email": "ahmed@example.com",
  "address": "456 Rue de la Paix",
  "zipCode": "75001"
}

