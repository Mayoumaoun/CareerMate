DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=career_mate_dev

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_ENDPOINT=/chat/completions
LLM_MODEL=openai/gpt-oss-20b:free
LLM_API_KEY=your-llm-api-key
LLM_API_KEY_HEADER=Authorization
LLM_API_KEY_PREFIX=Bearer
LLM_MAX_PROFILE_CHARS=2000
LLM_MAX_JOB_DESCRIPTION_CHARS=500
LLM_MAX_INPUT_TOKENS=12000
JOB_MATCHING_SCAN_LIMIT=200
JOB_MATCHING_DEFAULT_SHORTLIST_SIZE=10
JOB_MATCHING_MAX_SHORTLIST_SIZE=20

ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=gb

# JWT Authentication
JWT_TOKEN_SIGN_IN="modify the token - use a strong random string"
JWT_TOKEN_REFRESH="modify the refresh token - use a different strong random string"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# APIs
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key
GEMINI_API_KEY=your-gemini-api-key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=yourpassword
